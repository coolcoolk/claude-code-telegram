{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill|Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/token-gate.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill|Workflow|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 __PROJECT_ROOT__/routines/usage-gate.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
